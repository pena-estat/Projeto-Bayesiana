library(tidyverse)
library(nimble)
ads <- read.csv("/data/Advertising_Budget_and_Sales.csv")
getwd()
ads <- read.csv("C:/Users/User/Documents/GitHub/Projeto-Bayesiana/data/Advertising_Budget_and_Sales.csv")
